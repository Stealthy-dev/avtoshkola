---
import '../styles/global.css';
import { Icon } from 'astro-icon/components';
---

<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Автошкола Саваков — Русе. Шофьорски курсове за категории A, B, C, D. Запиши се онлайн.">
  <meta property="og:title" content="Автошкола Саваков | Русе">
  <meta property="og:description" content="Шофирай с увереност. Запиши се онлайн.">
  <title>Автошкола Саваков — Русе | Шофьорски курсове</title>

  <link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet">
</head>
<body>

  <!-- ============================================================
       SECTION 0 — TOP INFO BAR
  ============================================================ -->
  <div class="topbar">
    <div class="container">
      <div class="topbar__inner">
        <div class="topbar__left">
          <div class="topbar__addresses">
            <span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              бул. „Цар Освободител" 31, офис 1, Русе
            </span>
          </div>
        </div>
        <div class="topbar__right">
          <a href="tel:+359887572659">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 12 19.79 19.79 0 0 1 1.17 3.26 2 2 0 0 1 3.12 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16v.92z"/></svg>
            0887 572 659
          </a>
          <span class="topbar__sep">|</span>
          <a href="#" aria-label="Facebook" class="topbar__icon-link">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================
       SECTION 1 — STICKY NAVIGATION
  ============================================================ -->
  <header class="navbar" id="navbar" role="banner">
    <div class="container">
      <div class="navbar__inner">
        <a href="#hero" class="navbar__logo" aria-label="Начало">АВТОШКОЛА <span>Саваков</span></a>

        <nav class="navbar__nav" aria-label="Главна навигация">
          <a href="#hero">Начало</a>
          <a href="#categories">Курсове</a>

          <div class="nav-dropdown">
            <div class="nav-dropdown__trigger" tabindex="0" role="button" aria-haspopup="true">
              Категории <span class="caret">▾</span>
            </div>
            <div class="nav-dropdown__menu" role="menu">
              <a href="#categories" role="menuitem">Кат. А / А1 / А2 — Мотоциклети</a>
              <a href="#categories" role="menuitem">Кат. B — Леки автомобили</a>
              <a href="#categories" role="menuitem">Кат. B78 — Автоматик</a>
              <a href="#categories" role="menuitem">Кат. BE — С ремарке</a>
              <a href="#categories" role="menuitem">Кат. C — Товарни автомобили</a>
              <a href="#categories" role="menuitem">Кат. CE — Товарен с ремарке</a>
              <a href="#categories" role="menuitem">Кат. D — Автобуси</a>
              <a href="#categories" role="menuitem">Кат. D1 — Микробуси</a>
            </div>
          </div>

          <div class="nav-dropdown">
            <div class="nav-dropdown__trigger" tabindex="0" role="button" aria-haspopup="true">
              Услуги <span class="caret">▾</span>
            </div>
            <div class="nav-dropdown__menu" role="menu">
              <a href="#services" role="menuitem">Проф. компетентност</a>
              <a href="#services" role="menuitem">Възстановяване на точки</a>
              <a href="#services" role="menuitem">Опреснителни часове</a>
              <a href="#services" role="menuitem">АДР — Опасни товари</a>
              <a href="#services" role="menuitem">Мотокари / ПСМ</a>
            </div>
          </div>

          <a href="#why">За нас</a>
          <a href="#contact">Контакти</a>
        </nav>

        <div class="navbar__cta">
          <a href="#contact" class="btn btn-primary">ЗАПИШИ СЕ</a>
        </div>

        <button class="navbar__hamburger" id="hamburger" aria-label="Меню" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile drawer -->
  <div class="mobile-menu" id="mobileMenu" aria-label="Мобилна навигация">
    <a href="#hero" class="mobile-nav-link">Начало</a>
    <a href="#categories" class="mobile-nav-link">Курсове</a>

    <div class="mobile-group-title">Категории</div>
    <div class="mobile-sub">
      <a href="#categories" class="mobile-nav-link">Кат. А / А1 / А2</a>
      <a href="#categories" class="mobile-nav-link">Кат. B</a>
      <a href="#categories" class="mobile-nav-link">Кат. B78 — Автоматик</a>
      <a href="#categories" class="mobile-nav-link">Кат. BE</a>
      <a href="#categories" class="mobile-nav-link">Кат. C</a>
      <a href="#categories" class="mobile-nav-link">Кат. CE</a>
      <a href="#categories" class="mobile-nav-link">Кат. D</a>
      <a href="#categories" class="mobile-nav-link">Кат. D1</a>
    </div>

    <div class="mobile-group-title">Услуги</div>
    <div class="mobile-sub">
      <a href="#services" class="mobile-nav-link">Проф. компетентност</a>
      <a href="#services" class="mobile-nav-link">Възстановяване на точки</a>
      <a href="#services" class="mobile-nav-link">Опреснителни часове</a>
      <a href="#services" class="mobile-nav-link">АДР</a>
      <a href="#services" class="mobile-nav-link">Мотокари / ПСМ</a>
    </div>

    <a href="#why" class="mobile-nav-link">За нас</a>
    <a href="#contact" class="mobile-nav-link">Контакти</a>
    <div class="mobile-cta">
      <a href="#contact" class="btn btn-primary mobile-nav-link">ЗАПИШИ СЕ ОНЛАЙН</a>
    </div>
  </div>

  <main>

    <!-- ============================================================
         SECTION 2 — HERO
    ============================================================ -->
    <section class="hero" id="hero" aria-label="Начало">
      <div class="hero__glow"></div>
      <div class="container">
        <div class="hero__inner">
          <div class="hero__content">
            <div class="hero__badge"><Icon name="lucide:trophy" width="16" height="16" /> #1 Автошкола в Русе</div>
            <h1 class="hero__h1">
              Твоят път към<br>
              <em>свободата</em><br>
              започва тук.
            </h1>
            <p class="hero__subtitle">
              Записвай се онлайн. Гъвкав график. Опитни инструктори. Всички категории.
            </p>
            <div class="hero__buttons">
              <a href="#contact" class="btn btn-primary" style="font-size:16px;padding:16px 32px;">ЗАПИШИ СЕ ОНЛАЙН</a>
              <a href="#categories" class="btn btn-outline" style="font-size:16px;padding:16px 32px;">Виж курсовете ↓</a>
            </div>
            <div class="hero__trust">
              <span>
                <span class="check">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                </span>
                Над 1000 успешни курсисти
              </span>
              <span>
                <span class="check">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                </span>
                Лицензирана школа
              </span>
              <span>
                <span class="check">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                </span>
                Безплатна консултация
              </span>
            </div>
          </div>

          <div class="hero__image-wrap">
            <!-- src and alt are set by scripts/config.ts + scripts/main.ts -->
            <img class="hero__image" src="" alt="">
            <div class="hero__image-accent"></div>
          </div>
        </div>
      </div>

    </section>

    <!-- ============================================================
         SECTION 3 — STATS
    ============================================================ -->
    <section class="stats" id="stats" aria-label="Статистики">
      <div class="container">
        <div class="stats__inner">
          <div class="stats__item reveal">
            <div class="stats__number" data-target="1000" data-suffix="+">0</div>
            <div class="stats__label">Успешни курсисти</div>
          </div>
          <div class="stats__item reveal" style="transition-delay:0.1s">
            <div class="stats__number" data-target="15" data-suffix="+">0</div>
            <div class="stats__label">Години опит</div>
          </div>
          <div class="stats__item reveal" style="transition-delay:0.2s">
            <div class="stats__number" data-target="98" data-suffix="%">0</div>
            <div class="stats__label">Успеваемост</div>
          </div>
          <div class="stats__item reveal" style="transition-delay:0.3s">
            <div class="stats__number" data-target="8" data-suffix="">0</div>
            <div class="stats__label">Категории</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 4 — COURSE CATEGORIES
    ============================================================ -->
    <section class="categories" id="categories" aria-label="Категории">
      <div class="container">
        <div class="section-header reveal-title">
          <h2 class="section-title">Всички категории</h2>
          <p class="section-subtitle">От мотоциклет до камион — обучаваме за всички видове превозни средства.</p>
        </div>
        <div class="categories__grid">

          <div class="cat-card reveal" data-category="a">
            <div class="cat-card__icon">
              <Icon name="mdi:motorbike" width="40" height="40" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория А / А1 / А2</div>
            <div class="cat-card__desc">Мотоциклети и мотопеди</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.1s" data-category="b">
            <div class="cat-card__icon">
              <Icon name="mdi:car" width="40" height="40" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория B</div>
            <div class="cat-card__desc">Леки автомобили — ръчна скоростна кутия</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.15s" data-category="b78">
            <div class="cat-card__icon">
              <Icon name="mdi:car" width="40" height="40" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория B78</div>
            <div class="cat-card__desc">Леки автомобили — автоматична скоростна кутия</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.2s" data-category="be">
            <div class="cat-card__icon cat-card__icon--dual">
              <Icon name="mdi:car" style="color:#FF5C1A" />
              <span class="dual-sep"></span>
              <Icon name="mdi:caravan" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория BE</div>
            <div class="cat-card__desc">Лек автомобил с ремарке</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.25s" data-category="c">
            <div class="cat-card__icon">
              <Icon name="mdi:truck" width="40" height="40" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория C</div>
            <div class="cat-card__desc">Товарни автомобили над 3.5т</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.3s" data-category="ce">
            <div class="cat-card__icon cat-card__icon--dual">
              <Icon name="mdi:truck" style="color:#FF5C1A" />
              <span class="dual-sep"></span>
              <Icon name="mdi:caravan" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория CE</div>
            <div class="cat-card__desc">Товарен автомобил с ремарке</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.35s" data-category="d">
            <div class="cat-card__icon">
              <Icon name="mdi:bus" width="40" height="40" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория D</div>
            <div class="cat-card__desc">Автобуси — превоз на пътници</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <div class="cat-card reveal" style="transition-delay:0.4s" data-category="d1">
            <div class="cat-card__icon">
              <Icon name="mdi:van-passenger" width="40" height="40" style="color:#FF5C1A" />
            </div>
            <div class="cat-card__title">Категория D1</div>
            <div class="cat-card__desc">Микробуси до 16 места</div>
            <button type="button" class="cat-card__link">
              Детайли <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 5 — WHY CHOOSE US
    ============================================================ -->
    <section class="why" id="why" aria-label="Защо ние">
      <div class="container">
        <div class="why__inner">
          <div class="why__left">
            <div class="section-tag reveal-title">ЗАЩО НИЕ</div>
            <h2 class="why__title reveal-title">Различни от<br>всички останали.</h2>
            <p class="why__body reveal-title">
              Ние не просто учим шофиране — изграждаме увереност зад волана. В нашата школа ще намерите търпеливи инструктори, модерни автомобили и гъвкав график, съобразен с вашия живот. Нашата цел е вие да излезете от изпита като уверен и отговорен шофьор.
            </p>
            <ul class="why__list">
              <li class="reveal">
                <div class="check"><Icon name="lucide:check" width="14" height="14" /></div>
                <span>Индивидуален подход към всеки курсист</span>
              </li>
              <li class="reveal" style="transition-delay:0.1s">
                <div class="check"><Icon name="lucide:check" width="14" height="14" /></div>
                <span>Гъвкав график — уроци сутрин, обед и вечер</span>
              </li>
              <li class="reveal" style="transition-delay:0.15s">
                <div class="check"><Icon name="lucide:check" width="14" height="14" /></div>
                <span>Модерни и безопасни автомобили</span>
              </li>
              <li class="reveal" style="transition-delay:0.2s">
                <div class="check"><Icon name="lucide:check" width="14" height="14" /></div>
                <span>98% успеваемост на изпит от първи опит</span>
              </li>
              <li class="reveal" style="transition-delay:0.25s">
                <div class="check"><Icon name="lucide:check" width="14" height="14" /></div>
                <span>Онлайн записване и следене на напредъка</span>
              </li>
            </ul>
          </div>
          <div class="why__cards">
            <div class="why-card reveal">
              <div class="why-card__icon"><Icon name="lucide:calendar" width="28" height="28" /></div>
              <div class="why-card__title">Гъвкав график</div>
              <div class="why-card__desc">Записвай в удобен за теб ден и час — сутрин, обед или вечер.</div>
            </div>
            <div class="why-card reveal" style="transition-delay:0.1s">
              <div class="why-card__icon"><Icon name="lucide:graduation-cap" width="28" height="28" /></div>
              <div class="why-card__title">Опитни инструктори</div>
              <div class="why-card__desc">Търпеливи, ясни и подкрепящи — при нас никой не е сам.</div>
            </div>
            <div class="why-card reveal" style="transition-delay:0.15s">
              <div class="why-card__icon"><Icon name="lucide:car" width="28" height="28" /></div>
              <div class="why-card__title">Модерни автомобили</div>
              <div class="why-card__desc">Поддържан и безопасен автопарк с двойно управление.</div>
            </div>
            <div class="why-card reveal" style="transition-delay:0.2s">
              <div class="why-card__icon"><Icon name="lucide:smartphone" width="28" height="28" /></div>
              <div class="why-card__title">Онлайн записване</div>
              <div class="why-card__desc">Запиши се за 2 минути от телефона — без опашки, без хартия.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 6 — SERVICES
    ============================================================ -->
    <section class="services" id="services" aria-label="Допълнителни услуги">
      <div class="container">
        <div class="section-header reveal-title">
          <h2 class="section-title">Допълнителни услуги</h2>
          <p class="section-subtitle">Не само шофьорски курсове.</p>
        </div>
        <div class="services__grid">
          <div class="svc-card reveal">
            <div class="svc-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FF5C1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
            </div>
            <div class="svc-card__title">Възстановяване на точки</div>
            <div class="svc-card__desc">Курс за възстановяване на отнети контролни точки от СДВР.</div>
            <a href="#contact" class="svc-card__link">→ Запитване</a>
          </div>
          <div class="svc-card reveal" style="transition-delay:0.1s">
            <div class="svc-card__icon">
